{
  "_comment": "COMPONENT MANIFEST — Contrato entre Figma Make exports y producción Next.js",
  "_version": "1.0.0",
  "_updated": "2026-02-11",
  "_usage": "Leído por strip-figma.sh y por cualquier IA antes de migrar",

  "architecture": {
    "framework": "next-16-app-router",
    "routeGroups": {
      "(main)": {
        "layout": "app/(main)/layout.tsx",
        "includes": ["Header", "Footer", "GlobalWidgets"],
        "headerOffset": "pt-20 md:pt-24"
      },
      "(checkout)": {
        "layout": "app/(checkout)/checkout/layout.tsx",
        "includes": [],
        "note": "Sin Header/Footer, flujo limpio de checkout"
      }
    },
    "globalState": {
      "provider": "AppStateProvider en app/components/ClientProviders.tsx",
      "hook": "useAppState() de @/modules/app-state",
      "fields": ["isDarkMode", "language", "showWhatsApp", "showChat"],
      "toggles": ["toggleDarkMode", "toggleLanguage", "toggleWhatsApp", "toggleChat"]
    },
    "rules": {
      "header": "SOLO en (main)/layout.tsx — NUNCA dentro de componentes",
      "footer": "SOLO en (main)/layout.tsx — NUNCA dentro de componentes",
      "offset": "pt-20 md:pt-24 — SOLO en (main)/layout.tsx wrapper div",
      "colors": "SIEMPRE tokens (bg-background, text-foreground) — NUNCA hardcoded",
      "state": "SIEMPRE useAppState() — NUNCA props para isDarkMode/language",
      "navigation": "SIEMPRE <Link href> de next/link — NUNCA onNavigate callbacks"
    }
  },

  "figmaStripRules": {
    "_comment": "Qué eliminar de CUALQUIER export de Figma Make",
    "removeImports": [
      "import { Header }",
      "import { Footer }",
      "import { useNavigate }",
      "from 'react-router'",
      "from 'react-router-dom'"
    ],
    "removeJSX": [
      "<Header",
      "</Header>",
      "<Footer",
      "</Footer>"
    ],
    "removeMockData": [
      "const mockUser",
      "const mockOrders",
      "const mockAddresses",
      "const mockProducts",
      "const mockCart",
      "mockUser",
      "isAuthenticated: false",
      "isAuthenticated: true"
    ],
    "removeProps": [
      "language: 'es' | 'en'",
      "isDarkMode: boolean",
      "onToggleDarkMode",
      "onToggleLanguage",
      "onNavigate",
      "cartItemsCount",
      "isAuthenticated: boolean",
      "userName: string"
    ]
  },

  "components": {
    "Header.tsx": {
      "type": "layout-global",
      "destination": "src/modules/header/components/Header.tsx",
      "renderedBy": "app/(main)/layout.tsx",
      "figmaAction": "REPLACE_DESIGN_ONLY",
      "preserveLogic": ["useAuth()", "useCart()", "useAppState()", "useRouter()", "usePathname()"],
      "preserveImports": ["@/modules/auth", "@/modules/cart", "@/modules/app-state", "next/link", "next/navigation"],
      "requiredSections": {
        "mobile_menu": {
          "count": 6,
          "sections": [
            {"name": "navegacion", "verify": "/products"},
            {"name": "autenticacion", "verify": "isAuthenticated"},
            {"name": "servicios_recursos", "verify": "appointment"},
            {"name": "herramientas", "verify": "financing-calculator"},
            {"name": "configuracion", "verify": "toggleWhatsApp", "note": "4 toggles: idioma, darkMode, whatsApp, chat"},
            {"name": "legal", "verify": "/privacy"}
          ]
        }
      },
      "backupBefore": true
    },

    "Footer.tsx": {
      "type": "layout-global",
      "destination": "src/modules/footer/components/Footer.tsx",
      "renderedBy": "app/(main)/layout.tsx",
      "figmaAction": "REPLACE_DESIGN_ONLY",
      "preserveLogic": ["useAppState()"],
      "preserveImports": ["@/modules/app-state", "next/link"],
      "backupBefore": true
    },

    "LandingPage.tsx": {
      "type": "page-content",
      "destination": "src/modules/landing/components/LandingPage.tsx",
      "figmaAction": "STRIP_AND_REPLACE",
      "stripFromExport": ["Header", "Footer"],
      "injectContext": ["useAppState()"],
      "backupBefore": true
    },

    "AboutUs.tsx": {
