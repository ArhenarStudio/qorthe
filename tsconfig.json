{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ],
      "@/modules/*": [
        "./src/modules/*"
      ],
      "@/lib/module-manager/*": [
        "./src/lib/module-manager/*"
      ],
      "@/lib/module-manager": [
        "./src/lib/module-manager"
      ],
      "@/components/ui/*": [
        "./src/components/ui/*"
      ],
      "@/components/shared/*": [
        "./src/components/shared/*"
      ],
      "@/lib/shopify": [
        "./src/lib/shopify"
      ],
      "@/lib/shopify/*": [
        "./src/lib/shopify/*"
      ],
      "@/lib/supabase": [
        "./src/lib/supabase"
      ],
      "@/lib/supabase/*": [
        "./src/lib/supabase/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": [
    "node_modules",
    "src/modules/landing/versions/LandingPage.v2.tsx",
    "src/**/versions/**",
    "src/figma-versions/**"
  ]
}